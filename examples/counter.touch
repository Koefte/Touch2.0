<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
</head>
<body>
    <button onClick={count++}>Increment</button>
    <p>{"Count is: " + count}</p>
    <script type="module">
        Touch count = 0;
    </script>
</body>
</html>